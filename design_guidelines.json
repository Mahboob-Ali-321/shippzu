  "instructions_to_main_agent": [
    "Use Lucide-React-Native for consistent, modern iconography.",
    "Implement Reanimated or React Native Animated for smooth transitions, parallax effects, and bottom sheets.",
    "Use proper safe area views to avoid notches on modern iOS/Android devices.",
    "Ensure the bottom navigation bar has a glassmorphism effect using blur views where applicable, but ensure text/icons contrast is accessible.",
    "Build a context or Zustand/Redux store to handle Dark/Light mode theme switching dynamically.",
    "For typography, install `@expo-google-fonts/plus-jakarta-sans` or equivalent and load it asynchronously at splash screen.",
    "Apply `data-testid` to all clickable buttons, inputs, and interactive lists for E2E testing.",
    "Use skeleton loaders (Shimmer effects) for images and lists while data/images are fetching.",
    "Images should have a subtle dark overlay (`rgba(0,0,0,0.3)`) when text is layered over them (like restaurant hero images)."
  ],
  "UNIVERSAL_GUIDELINES_FOR_MAIN_AGENT": [
    "You tend to converge toward generic outputs. Avoid this: make creative, distinctive frontends that surprise and delight.",
    "Create depth through layered design elements with z-index hierarchy and drop shadows.",
    "Do not make generic centered layouts. Use asymmetrical or well-structured grids.",
    "Every interaction needs micro-animations (press in/out scale effects).",
    "Use 2-3x more spacing than feels comfortable. Cramped designs look cheap.",
    "Never use placeholder URLs (like via.placeholder.com). Use the provided image URLs.",
    "Never use transparent backgrounds on elements that have scrolling text beneath them without a blur.",
    "Always add data-testid to interactive elements."
  ]
}