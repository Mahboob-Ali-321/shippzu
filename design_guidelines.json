  "screens": {
    "splash": "Central Shippzu logo with subtle pulse/scale animation. Background: primary or pristine white.",
    "onboarding": "3 slides with high-quality illustrations or imagery. Smooth swipe with dot indicators. 'Skip' button top right, 'Next/Get Started' primary button at bottom.",
    "auth": "Clean inputs with generous padding. Social login options (Google, Apple) with distinct icons. OTP bottom sheet for phone login.",
    "location": "Map view taking up 60% of screen. Draggable bottom sheet with 'Use Current Location' button and search input. Smooth map pin animation.",
    "home": "Sticky header with user location and profile avatar. Large rounded search bar with voice icon. Horizontal scrolling category chips. Featured carousel with full-bleed images and gradient overlays. Vertical list for popular restaurants.",
    "restaurant_details": "Collapsing parallax header with hero image. Floating back button. Info card overlapping header with rating, time, fee. Horizontal scrolling menu categories (sticky). Food item list with veg/non-veg indicator and 'Add' button. Bottom sheet for variants.",
    "cart": "List of added items with quantity controls (+/-). Coupon input field. Detailed price breakdown. Sticky bottom CTA 'Proceed to Pay' with grand total.",
    "checkout": "Saved addresses horizontal scroll. Payment methods list with icons (UPI, Cards, COD). Primary 'Place Order' CTA.",
    "order_tracking": "Lottie animation for delivery partner. Timeline vertical stepper (placed -> preparing -> on the way -> delivered). Live map view. ETA prominent display.",
    "profile": "User info header. List menu items with left icon, right chevron (Orders, Favourites, Addresses, Settings, Theme Toggle, Logout)."
  },
